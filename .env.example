# GoBig local development — your machine (gitignored)
#
#   set -a && source .env && set +a
#   uvicorn app.main:app --reload --env-file .env

# JWT verification — REQUIRED
GOBIG_IAM_PUBLIC_KEY_PATH=./keys/iam_public_key.pem

# --- Redis ---
# Default if unset in code: redis://localhost:6379/0
# Remote with auth: redis://:PASSWORD@HOST:PORT/0  (do not commit real passwords here — use `.env`)
REDIS_URL=redis://:PASSWORD@HOST:PORT/0
# Optional timeouts (seconds).
# REDIS_SOCKET_CONNECT_TIMEOUT=1.5
# REDIS_SOCKET_TIMEOUT=2.5
# Social feed retention tunables.
GOBIG_SOCIAL_FEED_MAX_ITEMS=500
GOBIG_SOCIAL_EVENT_TTL_SECONDS=604800

# --- B2 / storage (API-M1-02, NLP staging) ---
# GOBIG_B2_PATHS_YAML=./gobig-documentation/b2_paths.yaml
# Upload gateway: origin only (no path). Client POSTs multipart `file=@...` to presigned_url.
GOBIG_PRESIGN_BASE_URL=http://example.com:3002
GOBIG_UPLOAD_API_PATH=/api/upload
GOBIG_NLP_STAGING_DIR=var/nlp-staging

# AI wrapper mock: `uvicorn scripts.mock_ai_wrapper:app --port 8099`
GOBIG_AI_WRAPPER_URL=http://localhost:8099

# Postgres (enabled for API-M1-03/API-M1-04 writes)
GOBIG_POSTGRES_ENABLED=1
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
GOBIG_POSTGRES_POOL_MIN_SIZE=1
GOBIG_POSTGRES_POOL_MAX_SIZE=5

# --- Dev-only: mint JWTs for curl/Postman (never enable in production) ---
# GOBIG_DEV_ALLOW_TOKEN_MINT=1
# GOBIG_IAM_PRIVATE_KEY_PATH=./keys/iam_private.pem

# --- Stripe webhook (API-M2-01) ---
# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

GOBIG_NLP_PROCESSING_FORCE_ON=1


# Local dev token minting (disable in any shared/prod-like env)
GOBIG_DEV_ALLOW_TOKEN_MINT=0
GOBIG_IAM_PRIVATE_KEY_PATH=./keys/iam_private.pem
# --- Sentry webhook (API-M2-02) ---
# HMAC secret used to verify `sentry-hook-signature` payload hashes
SENTRY_WEBHOOK_SECRET=replace-with-sentry-secret
# Slack incoming webhook URL for #platform-health alerts
SLACK_PLATFORM_HEALTH_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME

# --- Cloudflare KV sync (API-M2-03) ---
GOBIG_CF_API_TOKEN=cfut_REPLACE_ME
GOBIG_CF_ACCOUNT_ID=REPLACE_ME
GOBIG_CF_KV_NAMESPACE_ID=REPLACE_ME

# Optional overrides.
# GOBIG_CF_API_BASE_URL=https://api.cloudflare.com/client/v4
# GOBIG_CF_API_TIMEOUT_S=10
# GOBIG_CF_KV_RETRY_QUEUE_KEY=cf_kv_retry_queue

# --- Playbook execution API (API-M3-02) ---
# Approval token used by POST /api/v1/admin/playbook/{playbook_name}.
# In production, load this from B2 config source and inject at runtime.
GOBIG_PLAYBOOK_APPROVAL_TOKEN=replace-with-secure-token
# Optional file path alternative for local dev.
# GOBIG_PLAYBOOK_APPROVAL_TOKEN_PATH=./secrets/playbook_approval_token.txt
# Optional sandbox + timeout overrides.
# GOBIG_PLAYBOOKS_DIR=./scripts/playbooks
# GOBIG_PLAYBOOK_TIMEOUT_S=30
# GOBIG_B2_PLAYBOOK_AUDIT_DIR=var/b2-audit/playbooks

# --- Flower proxy admin API (API-M3-03) ---
# Upstream Flower base URL and timeout budget (seconds).
GOBIG_FLOWER_BASE_URL=http://flower.example.local:5555
GOBIG__TIMEOUT_S=5
# Immutable audit dir for retry actions.
# GOBIG_B2_JOB_AUDIT_DIR=var/b2-audit/jobs
